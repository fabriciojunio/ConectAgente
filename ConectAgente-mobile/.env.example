# ============================================================
# ConectAgente — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env no git!
#
# COMO OBTER AS VARIÁVEIS DO SUPABASE:
# 1. Acesse https://supabase.com e crie uma conta gratuita
# 2. Crie um novo projeto
# 3. Vá em: Project Settings → API
# 4. Copie a "Project URL" e a "anon public" key
# ============================================================

EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API própria (opcional — se não usar Supabase direto)
EXPO_PUBLIC_API_URL=https://sua-api.com/v1
